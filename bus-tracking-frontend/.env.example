# ============================================================
# SMART BUS TRACKING — FRONTEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values.
# Vite exposes only variables prefixed with VITE_ to the browser.
# ============================================================

# Backend API base URL (used by Vite dev proxy + production build)
VITE_API_URL=http://localhost:5000/api

# Socket.IO server URL
VITE_SOCKET_URL=http://localhost:5000

# App name shown in the browser tab
VITE_APP_NAME=Smart Bus Tracker
