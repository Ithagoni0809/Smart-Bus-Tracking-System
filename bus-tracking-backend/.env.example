# ============================================================
# SMART BUS TRACKING SYSTEM - ENVIRONMENT VARIABLES
# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR OWN VALUES
# NEVER commit .env to GitHub — it contains secrets!
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
# The port your backend server will listen on
PORT=5000

# The environment: development | production | test
NODE_ENV=development

# The full URL of your frontend (used for CORS + email links)
CLIENT_URL=http://localhost:5173

# ── DATABASE ─────────────────────────────────────────────────
# Your MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Connect → Drivers → Node.js
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://bharathithagoni_db_user:Oz9XT79HHv7qLfz8@cluster0.dqrhtan.mongodb.net/?appName=Cluster0

# ── JWT (JSON Web Token) ─────────────────────────────────────
# Secret keys used to sign tokens. MUST be long random strings.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Access token: short-lived (used for API requests)
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRE=24h

# Refresh token: long-lived (used to get new access tokens)
JWT_REFRESH_SECRET=
# ── EMAIL (for verification + password reset) ─────────────────
# Using Gmail SMTP as example. For production, use SendGrid or Mailgun.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
# For Gmail: use an App Password (not your real password)
# Settings → Security → 2-Step Verification → App Passwords
EMAIL_PASSWORD=
EMAIL_FROM_NAME=Smart Bus Tracking
EMAIL_FROM_ADDRESS=noreply@smartbustracking.com

# ── RATE LIMITING ────────────────────────────────────────────
# How many requests allowed per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── ENCRYPTION ───────────────────────────────────────────────
# Used to hash password reset tokens before storing
CRYPTO_SECRET=
